{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('app.css', 'easyadmin.assets.package') }}">
    <style>
        body {
            align-items: center;
            background-color: #f5f5f5;
            display: flex;
            justify-content: center;
            margin: 0;
        }
        .form-register {
            max-width: 320px;
            text-align: center;
            width: 100%;
        }
        .form-register input {
            position: relative;
        }
        .form-register input[name="_username"] {
            border-bottom-left-radius: 0;
            border-bottom-right-radius: 0;
            margin-bottom: -1px;
        }
        .form-register input[name="_password"] {
            border-top-left-radius: 0;
            border-top-right-radius: 0;
        }
        .form-register input:focus {
            z-index: 1;
        }
    </style>
{% endblock %}

{% block body %}
    <form class="form-register" action="{{ path('app_register') }}" method="post">
        <img class="mb-3" src="{{ asset('favicon.svg') }}" alt="Personal Accountant" width="72" height="72">

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <label class="sr-only" for="username">Username</label>
        <input class="form-control w-100 py-2" type="text" id="username" name="_username" placeholder="Username" required autofocus>

        <label class="sr-only" for="password">Password</label>
        <input class="form-control w-100 py-2" type="password" id="password" name="_password" placeholder="Password" required>

        <button class="btn btn-primary w-100 mt-3 py-4 fs-5 justify-content-center">
            Register
        </button>

        <p class="mt-5 mb-3 text-muted">
            <a
                class="text-decoration-underline link-primary link-underline-primary link-offset-2 link-underline-opacity-25 link-underline-opacity-100-hover"
                href="https://github.com/vchychuzhko/personal-accountant"
                target="_blank"
            >GitHub</a>
            &copy; vchychuzhko
        </p>
    </form>
{% endblock %}
